<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Embed Studio - Staff Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #05070a;
            --accent-blue: #3b82f6;
            --glass-bg: rgba(15, 23, 42, 0.6);
            --border-color: rgba(255, 255, 255, 0.08);
        }
        
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg-dark); color: #f8fafc; }
        .bg-mesh { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; background: radial-gradient(circle at 0% 0%, rgba(59, 130, 246, 0.1) 0%, transparent 40%); }
        .glass { background: var(--glass-bg); backdrop-filter: blur(16px); border: 1px solid var(--border-color); }
        .active-nav { background: linear-gradient(90deg, rgba(59, 130, 246, 0.15), transparent); color: #60a5fa; border-left: 3px solid var(--accent-blue); font-weight: 700; }
        
        .discord-embed { background: #2f3136; border-radius: 4px; border-left: 4px solid #3b82f6; transition: border-color 0.3s ease; }
        .input-dark { background: rgba(15, 23, 42, 0.8); border: 1px solid rgba(255, 255, 255, 0.1); transition: all 0.3s ease; }
        .input-dark:focus { border-color: var(--accent-blue); box-shadow: 0 0 15px rgba(59, 130, 246, 0.2); outline: none; }
    </style>
</head>
<body class="min-h-screen flex">
    <div class="bg-mesh"></div>

    <!-- Sidebar -->
    <aside class="w-72 glass border-r border-slate-800 p-8 flex flex-col">
        <div class="flex items-center space-x-3 mb-12">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center">
                <span class="text-white font-bold text-xl">V</span>
            </div>
            <h1 class="text-xl font-extrabold tracking-tight">OFICIAL<span class="text-blue-500">BOT</span></h1>
        </div>

        <nav class="space-y-3 flex-1">
            <a href="/" class="flex items-center space-x-4 p-4 rounded-xl text-slate-400 hover:text-white group transition-all">
                <span>🏠</span>
                <span class="font-medium">Overview</span>
            </a>
            <a href="/embeds" class="flex items-center space-x-4 p-4 rounded-xl active-nav">
                <span>📑</span>
                <span class="font-medium">Embed Studio</span>
            </a>
        </nav>
        
        <div class="pt-8 border-t border-slate-800/50">
            <div class="glass rounded-2xl p-4 flex items-center space-x-4">
                <div class="w-11 h-11 rounded-full bg-slate-800 overflow-hidden">
                    <img src="https://cdn.discordapp.com/embed/avatars/0.png" alt="Bot Avatar" class="w-full h-full">
                </div>
                <div class="overflow-hidden">
                    <p class="text-sm font-bold truncate"><%= botName %></p>
                    <p class="text-[10px] text-blue-400 font-semibold tracking-wider uppercase">Online Now</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 p-12 overflow-y-auto">
        <header class="mb-12">
            <h2 class="text-4xl font-extrabold mb-3 tracking-tight">Embed <span class="text-blue-500">Studio</span></h2>
            <p class="text-slate-400 text-lg">Diseña y despliega anuncios profesionales al instante.</p>
        </header>

        <% if (locals.message) { %>
            <div class="mb-8 p-6 rounded-[1.5rem] glass border-l-4 <%= messageType === 'success' ? 'border-green-500/50 bg-green-500/5 text-green-400' : 'border-red-500/50 bg-red-500/5 text-red-400' %>">
                <div class="flex items-center space-x-3 font-bold">
                    <span><%= messageType === 'success' ? '✅' : '❌' %></span>
                    <span><%= message %></span>
                </div>
            </div>
        <% } %>

        <form action="/embeds/send" method="POST" class="grid grid-cols-1 xl:grid-cols-2 gap-12">
            <div class="glass p-10 rounded-[2.5rem] space-y-8">
                <div class="space-y-3">
                    <label class="block text-xs font-black text-slate-500 uppercase tracking-widest ml-1">Configuración de Canal</label>
                    <select name="channelId" required class="w-full input-dark rounded-2xl p-4 text-white appearance-none cursor-pointer">
                        <% channels.forEach(channel => { %>
                            <option value="<%= channel.id %>"># <%= channel.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="space-y-3">
                    <label class="block text-xs font-black text-slate-500 uppercase tracking-widest ml-1">Encabezado</label>
                    <input type="text" name="title" id="input-title" required class="w-full input-dark rounded-2xl p-4 text-white" placeholder="Título impactante...">
                </div>

                <div class="space-y-3">
                    <label class="block text-xs font-black text-slate-500 uppercase tracking-widest ml-1">Cuerpo del Mensaje</label>
                    <textarea name="description" id="input-description" required rows="6" class="w-full input-dark rounded-2xl p-4 text-white" placeholder="Escribe el mensaje aquí..."></textarea>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div class="space-y-3">
                        <label class="block text-xs font-black text-slate-500 uppercase tracking-widest ml-1">Acento de Color</label>
                        <input type="text" name="color" id="input-color" value="#3b82f6" class="w-full input-dark rounded-2xl p-4 text-white">
                    </div>
                    <div class="space-y-3">
                        <label class="block text-xs font-black text-slate-500 uppercase tracking-widest ml-1">Pie de Página</label>
                        <input type="text" name="footer" id="input-footer" class="w-full input-dark rounded-2xl p-4 text-white" placeholder="Créditos o info extra">
                    </div>
                </div>

                <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-black py-5 rounded-[1.5rem] transition-all duration-300 transform hover:scale-[1.02] shadow-xl shadow-blue-600/20 text-lg uppercase tracking-wider">
                    Desplegar Anuncio
                </button>
            </div>

            <div class="space-y-6 sticky top-0">
                <div class="flex items-center space-x-3 mb-2">
                    <div class="w-2 h-6 bg-blue-500 rounded-full"></div>
                    <h3 class="text-xl font-bold">Vista Previa Live</h3>
                </div>
                
                <div class="p-8 glass rounded-[2.5rem] bg-slate-900/40">
                    <div id="preview-card" class="discord-embed p-4 shadow-2xl">
                        <div class="flex items-center space-x-2 mb-4">
                            <div class="w-7 h-7 rounded-full bg-slate-700 flex items-center justify-center text-[10px]">🤖</div>
                            <span class="text-sm font-black text-white">OFICIAL BOT</span>
                            <span class="bg-[#5865f2] text-[9px] text-white px-1.5 py-0.5 rounded-sm font-bold uppercase tracking-tighter">Bot</span>
                            <span class="text-slate-500 text-[10px] ml-1">Hoy a las 12:00</span>
                        </div>
                        <div id="preview-title" class="text-white text-lg font-bold mb-2">Título del Embed</div>
                        <div id="preview-description" class="text-slate-300 text-sm leading-relaxed whitespace-pre-wrap">Aquí se mostrará el contenido que escribas en el formulario.</div>
                        <div class="text-slate-400 text-[11px] mt-4 flex items-center space-x-2">
                            <span id="preview-footer">Staff Team</span>
                        </div>
                    </div>
                </div>
                
                <div class="p-6 glass rounded-2xl bg-blue-500/5 border-blue-500/20 text-xs text-blue-400 leading-relaxed italic">
                    💡 <strong>Pro Tip:</strong> Usa el botón "Desplegar Anuncio" solo cuando estés satisfecho con la vista previa. El mensaje se enviará instantáneamente al canal seleccionado.
                </div>
            </div>
        </form>
    </main>

    <script>
        const inputs = {
            title: document.getElementById('input-title'),
            description: document.getElementById('input-description'),
            color: document.getElementById('input-color'),
            footer: document.getElementById('input-footer')
        };

        const previews = {
            card: document.getElementById('preview-card'),
            title: document.getElementById('preview-title'),
            description: document.getElementById('preview-description'),
            footer: document.getElementById('preview-footer')
        };

        function updatePreview() {
            previews.title.textContent = inputs.title.value || 'Título del Embed';
            previews.description.textContent = inputs.description.value || 'Aquí se mostrará el contenido que escribas en el formulario.';
            previews.footer.textContent = inputs.footer.value || 'Staff Team';
            
            let color = inputs.color.value;
            if (!color.startsWith('#')) color = '#' + color;
            if (/^#[0-9A-F]{6}$/i.test(color)) previews.card.style.borderColor = color;
        }

        Object.values(inputs).forEach(input => input.addEventListener('input', updatePreview));
        updatePreview();
    </script>
</body>
</html>