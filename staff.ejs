<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Equipo Staff - Staff Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #05070a;
            --accent-blue: #3b82f6;
            --glass-bg: rgba(15, 23, 42, 0.6);
            --border-color: rgba(255, 255, 255, 0.08);
        }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: var(--bg-dark); color: #f8fafc; }
        .bg-mesh { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; background: radial-gradient(circle at 100% 0%, rgba(59, 130, 246, 0.1) 0%, transparent 40%); }
        .glass { background: var(--glass-bg); backdrop-filter: blur(16px); border: 1px solid var(--border-color); }
        .active-nav { background: linear-gradient(90deg, rgba(59, 130, 246, 0.15), transparent); color: #60a5fa; border-left: 3px solid var(--accent-blue); font-weight: 700; }
        .staff-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .staff-card:hover { transform: translateY(-5px); background: rgba(30, 41, 59, 0.8); border-color: rgba(59, 130, 246, 0.3); }
    </style>
</head>
<body class="min-h-screen flex">
    <div class="bg-mesh"></div>

    <!-- Sidebar -->
    <aside class="w-72 glass border-r border-slate-800 p-8 flex flex-col">
        <div class="flex items-center space-x-3 mb-12">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center">
                <span class="text-white font-bold text-xl">V</span>
            </div>
            <h1 class="text-xl font-extrabold tracking-tight">OFICIAL<span class="text-blue-500">BOT</span></h1>
        </div>

        <nav class="space-y-3 flex-1">
            <a href="/" class="flex items-center space-x-4 p-4 rounded-xl text-slate-400 hover:text-white group transition-all">
                <span>🏠</span>
                <span class="font-medium">Overview</span>
            </a>
            <a href="/embeds" class="flex items-center space-x-4 p-4 rounded-xl text-slate-400 hover:text-white group transition-all">
                <span>📑</span>
                <span class="font-medium">Embed Studio</span>
            </a>
            <a href="/staff" class="flex items-center space-x-4 p-4 rounded-xl active-nav">
                <span>👑</span>
                <span class="font-medium">Equipo Staff</span>
            </a>
        </nav>
        
        <div class="pt-8 border-t border-slate-800/50">
            <div class="glass rounded-2xl p-4 flex items-center space-x-4">
                <div class="w-11 h-11 rounded-full bg-slate-800 overflow-hidden">
                    <img src="https://cdn.discordapp.com/embed/avatars/0.png" alt="Bot Avatar" class="w-full h-full">
                </div>
                <div>
                    <p class="text-sm font-bold truncate"><%= botName %></p>
                    <p class="text-[10px] text-blue-400 font-semibold uppercase">Online</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 p-12 overflow-y-auto">
        <header class="mb-12">
            <h2 class="text-4xl font-extrabold mb-3 tracking-tight">Equipo <span class="text-blue-500">Staff</span></h2>
            <p class="text-slate-400 text-lg">Jerarquía y estructura actual del equipo de gestión.</p>
        </header>

        <div class="space-y-16">
            <% staffList.forEach(roleGroup => { %>
                <section>
                    <div class="flex items-center space-x-4 mb-8">
                        <div class="h-1 w-12 bg-blue-600 rounded-full"></div>
                        <h3 class="text-2xl font-black uppercase tracking-widest text-slate-300"><%= roleGroup.label %></h3>
                        <span class="bg-blue-600/10 text-blue-500 text-xs px-3 py-1 rounded-full font-bold border border-blue-500/20">
                            <%= roleGroup.members.length %> Integrantes
                        </span>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                        <% roleGroup.members.forEach(member => { %>
                            <div class="staff-card glass p-6 rounded-[2rem] flex flex-col items-center text-center">
                                <div class="relative mb-4">
                                    <div class="w-20 h-20 rounded-[1.5rem] bg-slate-800 overflow-hidden border-2 border-slate-700/50 shadow-2xl">
                                        <img src="<%= member.avatar %>" alt="Avatar" class="w-full h-full object-cover">
                                    </div>
                                    <div class="absolute -bottom-1 -right-1 w-6 h-6 bg-blue-600 rounded-lg flex items-center justify-center text-[10px] border-2 border-[#05070a]">👑</div>
                                </div>
                                <p class="text-white font-bold text-lg mb-1 truncate w-full"><%= member.tag %></p>
                                <p class="text-slate-500 text-[10px] font-mono"><%= member.id %></p>
                                
                                <div class="mt-4 flex space-x-2">
                                    <span class="px-3 py-1 bg-slate-800/50 rounded-lg text-[9px] font-bold text-slate-400 uppercase tracking-tighter">Verified</span>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </section>
            <% }) %>

            <% if (staffList.length === 0) { %>
                <div class="glass p-12 rounded-[2.5rem] text-center">
                    <p class="text-slate-400 text-xl font-bold">No hay miembros del staff registrados por el momento.</p>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>